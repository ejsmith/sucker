{
  "name": "sucker",
  "version": "1.1.0",
  "license": "MIT",
  "expo": {
    "autolinking": {
      "ios": {
        "buildFromSource": [
          "react-native-reanimated",
          "react-native-worklets"
        ]
      }
    }
  },
  "main": "index.ts",
  "dependencies": {
    "@exceptionless/react-native": "^3.2.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@supabase/supabase-js": "^2.110.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "expo": "^57.0.4",
    "expo-application": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "expo-doctor": "^1.20.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.3",
    "supabase": "^2.109.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "node scripts/start-web.cjs",
    "build:web": "expo export --platform web --output-dir dist --source-maps external",
    "check:bundle-size": "node scripts/check-web-bundle-size.cjs",
    "check:expo": "expo install --check",
    "doctor:expo": "expo-doctor",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "optimize:assets": "node scripts/optimize-assets.cjs",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "deno check supabase/functions/game-action/index.ts",
    "test:edge": "deno test supabase/functions",
    "prepare:e2e-env": "node scripts/supabase-test-env.cjs",
    "test:integration:supabase": "node scripts/test-supabase-integration.cjs",
    "test:e2e:web": "node scripts/test-web-e2e.cjs",
    "test": "tsc --project tsconfig.rules.json && node --test tests/*.test.cjs",
    "ai-counterfactual": "tsc --project tsconfig.rules.json && node scripts/ai-counterfactual.cjs",
    "ai-optimizer": "tsc --project tsconfig.rules.json && node scripts/ai-optimizer.cjs",
    "ai-lab": "tsc --project tsconfig.rules.json && node scripts/ai-lab.cjs",
    "simulate:computer": "tsc --project tsconfig.rules.json && node scripts/simulate-computer.cjs",
    "tournament:computer": "tsc --project tsconfig.rules.json && node scripts/tournament-computer.cjs",
    "tournament:sucker-tokens": "tsc --project tsconfig.rules.json && node scripts/tournament-sucker-tokens.cjs"
  },
  "private": true
}
